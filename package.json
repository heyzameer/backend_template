{
    "name": "backend-template",
    "version": "1.0.0",
    "description": "Production-ready Node.js + TypeScript backend template with Auth, RBAC, Google OAuth",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/main.js",
        "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "clean": "rimraf dist",
        "prepare": "node -e \"if (process.env.NODE_ENV !== 'production') { try { require('child_process').execSync('husky') } catch (e) {} }\""
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "chalk": "^4.1.2",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.18.2",
        "express-rate-limit": "^6.10.0",
        "helmet": "^7.0.0",
        "ioredis": "^5.9.2",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^7.6.3",
        "morgan": "^1.10.0",
        "nodemailer": "^7.0.12",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "reflect-metadata": "^0.2.2",
        "tsyringe": "^4.10.0",
        "winston": "^3.10.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.5",
        "@types/compression": "^1.7.4",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.15",
        "@types/express": "^4.17.20",
        "@types/jest": "^29.5.6",
        "@types/jsonwebtoken": "^9.0.4",
        "@types/morgan": "^1.9.7",
        "@types/node": "^20.8.6",
        "@types/nodemailer": "^6.4.13",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.17",
        "@types/supertest": "^2.0.15",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "eslint": "^8.57.1",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "rimraf": "^5.0.5",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.2.2"
    },
    "keywords": [
        "nodejs",
        "typescript",
        "express",
        "mongodb",
        "auth",
        "rbac",
        "google-oauth"
    ],
    "author": "Your Name",
    "license": "MIT"
}
